# ─── Frost Auth Server ───────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before deploying.

# HTTP port (Railway sets this automatically)
PORT=3000

# TCP auth port
TCP_PORT=4000

# Internal API key shared between bot and server.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_KEY=change_me_to_a_random_64_char_hex_string

# Fragment secret — MUST stay the same across restarts or all active users break.
# Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then copy the output here and never change it.
FRAGMENT_SECRET=change_me_to_a_random_64_char_hex_string

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Discord application / client ID
DISCORD_CLIENT_ID=your_discord_client_id_here
